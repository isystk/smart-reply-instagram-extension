{
  "manifest_version": 3,
  "name": "Instagram Reply Assistant",
  "version": "1.0.0",
  "description": "AI-powered reply assistant for Instagram",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Instagram Reply Assistant"
  }
}
